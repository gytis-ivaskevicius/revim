╭────────────────────────────────────────────────────────────────────────────────╮
│┌ReVim─────────────────────────────────────────────────────────────────────────┐│
││Welcome to ReVim!                                                             ││
││This is a line of text.                                                       ││
││ReVim is a terminal-based text editor.                                        ││
││It mimics the behavior of Vim.                                                ││
││                                                                              ││
││Basic movement keys:                                                          ││
││  h - move left                                                               ││
││  j - move down                                                               ││
││  k - move up                                                                 ││
││  l - move right                                                              ││
││                                                                              ││
││Word motion:                                                                  ││
││  w - next word                                                               ││
││  b - previous word                                                           ││
││  e - end of word                                                             ││
││                                                                              ││
││Line numbers are not shown yet.                                               ││
││Visual mode selection works.                                                  ││
││You can delete, yank, and put text.                                           ││
││                                                                              ││
││Insert mode:                                                                  ││
││  i - insert before cursor                                                    ││
││  a - insert after cursor                                                     ││
││  A - append at line end                                                      ││
││  o - open new line below                                                     ││
││  O - open new line above                                                     ││
││                                                                              ││
│└──────────────────────────────────────────────────────────────────────────────┘│
│V-BLOCK                                                                         │
╰────────────────────────────────────────────────────────────────────────────────╯
{
  "0,0": {
    "bgColorMode": 0,
    "bgColor": -1,
    "fgColorMode": 0,
    "fgColor": -1,
    "blink": 0,
    "bold": 0,
    "dim": 0,
    "inverse": 0,
    "invisible": 0,
    "italic": 0,
    "overline": 0,
    "strike": 0,
    "underline": 0
  },
  "9,1": {
    "inverse": 67108864
  },
  "11,1": {
    "inverse": 0
  }
}
`;

